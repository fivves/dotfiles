#!/usr/bin/env bash
set -Eeuo pipefail

usage() {
  printf 'Usage: %s [youtube-url]\n' "${0##*/}" >&2
}

arch_install_help() {
  printf '%s\n' \
    'Install missing dependencies on Arch-based systems with:' \
    '  sudo pacman -S mpv yt-dlp wl-clipboard' >&2
}

require_command() {
  local name=$1
  local package=$2

  if ! command -v "$name" >/dev/null 2>&1; then
    printf 'Missing dependency: %s (package: %s)\n' "$name" "$package" >&2
    return 1
  fi
}

check_dependencies() {
  local missing=0

  require_command mpv mpv || missing=1
  require_command yt-dlp yt-dlp || missing=1
  require_command wl-paste wl-clipboard || missing=1

  if (( missing )); then
    arch_install_help
    exit 127
  fi
}

notify_loading() {
  local start=$1
  local message='Resolving stream with yt-dlp...'

  command -v notify-send >/dev/null 2>&1 || return 0

  if [[ -n $start ]]; then
    message="Resolving stream with yt-dlp and starting at $start."
  fi

  notify-send --app-name='yt-mpv-time' --expire-time=4000 \
    'Loading YouTube in mpv' "$message" >/dev/null 2>&1 || true
}

read_url() {
  if (( $# > 1 )); then
    usage
    exit 2
  fi

  if (( $# == 1 )); then
    printf '%s' "$1"
    return
  fi

  wl-paste --no-newline
}

format_seconds() {
  local total=$1
  local hours=$(( total / 3600 ))
  local minutes=$(( (total % 3600) / 60 ))
  local seconds=$(( total % 60 ))

  if (( hours > 0 )); then
    printf '%d:%02d:%02d' "$hours" "$minutes" "$seconds"
  else
    printf '%d:%02d' "$minutes" "$seconds"
  fi
}

parse_timestamp() {
  local raw=${1,,}
  local rest total hours minutes seconds

  # YouTube sometimes appends extra data after the timestamp value.
  raw=${raw%%[!0-9hms:]*}

  if [[ $raw =~ ^[0-9]+$ ]]; then
    printf '%s' "$raw"
    return 0
  fi

  if [[ $raw =~ ^[0-9]+s$ ]]; then
    printf '%s' "${raw%s}"
    return 0
  fi

  if [[ $raw =~ ^([0-9]+):([0-9]{1,2})(:([0-9]{1,2}))?$ ]]; then
    printf '%s' "$raw"
    return 0
  fi

  rest=$raw
  total=0

  if [[ $rest =~ ^([0-9]+)h ]]; then
    hours=${BASH_REMATCH[1]}
    total=$(( total + hours * 3600 ))
    rest=${rest#${hours}h}
  fi

  if [[ $rest =~ ^([0-9]+)m ]]; then
    minutes=${BASH_REMATCH[1]}
    total=$(( total + minutes * 60 ))
    rest=${rest#${minutes}m}
  fi

  if [[ $rest =~ ^([0-9]+)s?$ ]]; then
    seconds=${BASH_REMATCH[1]}
    total=$(( total + seconds ))
    rest=${rest#${seconds}}
    rest=${rest#s}
  fi

  if [[ -z $rest && $total -gt 0 ]]; then
    format_seconds "$total"
    return 0
  fi

  return 1
}

process_params() {
  local input=$1
  local output_var=$2
  local start_var=$3
  local IFS='&'
  local param name value
  local -a kept=()

  read -r -a params <<< "$input"

  # Keep unrelated query parameters intact, but remove t/start before mpv sees the URL.
  for param in "${params[@]}"; do
    [[ -z $param ]] && continue
    name=${param%%=*}
    value=
    [[ $param == *=* ]] && value=${param#*=}

    if [[ $name == t || $name == start ]]; then
      if [[ -z ${!start_var} ]] && parse_timestamp "$value" >/dev/null; then
        printf -v "$start_var" '%s' "$(parse_timestamp "$value")"
      fi
      continue
    fi

    kept+=("$param")
  done

  local joined=
  for param in "${kept[@]}"; do
    if [[ -z $joined ]]; then
      joined=$param
    else
      joined+="&$param"
    fi
  done

  printf -v "$output_var" '%s' "$joined"
}

clean_url_and_find_start() {
  local url=$1
  local before_fragment fragment base query cleaned_query cleaned_fragment
  local cleaned start=

  before_fragment=${url%%#*}
  fragment=
  [[ $url == *#* ]] && fragment=${url#*#}

  # Process query and fragment separately so links like ?v=...#t=1m30s work too.
  base=${before_fragment%%\?*}
  query=
  [[ $before_fragment == *\?* ]] && query=${before_fragment#*\?}

  process_params "$query" cleaned_query start
  process_params "$fragment" cleaned_fragment start

  cleaned=$base
  [[ -n $cleaned_query ]] && cleaned+="?$cleaned_query"
  [[ -n $cleaned_fragment ]] && cleaned+="#$cleaned_fragment"

  printf '%s\t%s\n' "$cleaned" "$start"
}

main() {
  check_dependencies

  local url cleaned start
  url=$(read_url "$@")

  if [[ -z $url ]]; then
    printf 'No URL provided and clipboard is empty.\n' >&2
    exit 2
  fi

  IFS=$'\t' read -r cleaned start < <(clean_url_and_find_start "$url")

  if [[ ${YT_MPV_TIME_DRY_RUN:-0} == 1 ]]; then
    if [[ -n $start ]]; then
      printf 'mpv --start=%q %q\n' "$start" "$cleaned"
    else
      printf 'mpv %q\n' "$cleaned"
    fi
    return
  fi

  notify_loading "$start"

  if [[ -n $start ]]; then
    exec mpv --start="$start" "$cleaned"
  fi

  exec mpv "$cleaned"
}

main "$@"
