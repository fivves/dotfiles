{
  "reload_style_on_change": true,
  "layer": "top",
  "position": "top",
  "spacing": 0,

  "modules-left": [
    "custom/omarchy",
    "group/left-main",
    "custom/codexbar",
    "mpris"
  ],

  "modules-center": ["hyprland/window"],
  
  "modules-right": [
    "custom/cava",
    "custom/wordle",
    "custom/twitch",
    "custom/weather",
    "group/right-icons",
    "clock"
  ],

  "group/left-main": {
    "orientation": "inherit",
    "modules": ["hyprland/workspaces"]
  },

  "group/right-icons": {
    "orientation": "inherit",
    "modules": [
      "custom/screenrecording-indicator",
      "group/tray-expander",
      "bluetooth",
      "network",
      "battery",
      "pulseaudio",
      "custom/idle-indicator",
      "custom/notification-silencing-indicator",
      "custom/update"
    ]
  },

  "group/tray-expander": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
      "children-class": "tray-group-item"
    },
    "modules": ["custom/expand-icon", "tray"]
  },

  "custom/omarchy": {
    "format": "<span font='Flighter PERSONAL USE ONLY'> lucitt </span>",
    "on-click": "omarchy-menu",
    "on-click-right": "omarchy-launch-terminal",
    "tooltip-format": "Omarchy Menu\n\nSuper + Alt + Space"
  },

  "custom/codexbar": {
    "exec": "codexbar",
    "format": "ůįö© {}",
    "return-type": "json",
    "interval": 300,
    "signal": 12,
    "tooltip": true,
    "on-click": "xdg-open https://chatgpt.com/codex/settings/usage"
  },

"custom/weather": {
    "format": "{}ÓćĀ",
    "tooltip": true,
    "interval": 3600,
    "exec": "wttrbar --fahrenheit --nerd",
    "return-type": "json"
},

  "custom/wordle": {
    "exec": "python3 ~/.config/waybar/scripts/wordle.py",
    "return-type": "json",
    "interval": 3600,
    "signal": 8,
    "exec-on-event": false,
    "on-click": "bash ~/.config/waybar/scripts/wordle-guess.sh",
    "format": "{}",
    "tooltip": true,
    "escape": false
  },

  "custom/twitch": {
    "exec": "python3 ~/.config/waybar/scripts/twitch.py",
    "return-type": "json",
    "interval": 300,
    "format": "{}",
    "tooltip": true,
    "escape": true,
    "on-click": "bash ~/.config/waybar/scripts/twitch-menu.sh"
  },

  "custom/cava": {
    "exec": "bash ~/.config/waybar/scripts/cava.sh",
    "return-type": "json",
    "format": "{}",
    "exec-on-event": false,
    "tooltip": false
  },

  "custom/update": {
    "format": "ÔÄ°",
    "exec": "omarchy-update-available",
    "on-click": "omarchy-launch-floating-terminal-with-presentation omarchy-update",
    "tooltip-format": "Omarchy update available",
    "signal": 7,
    "interval": 3600
  },

  "custom/idle-indicator": {
    "on-click": "omarchy-toggle-idle",
    "exec": "$OMARCHY_PATH/default/waybar/indicators/idle.sh",
    "signal": 9,
    "return-type": "json"
  },

  "custom/notification-silencing-indicator": {
    "on-click": "omarchy-toggle-notification-silencing",
    "exec": "$OMARCHY_PATH/default/waybar/indicators/notification-silencing.sh",
    "signal": 10,
    "return-type": "json"
  },

  "custom/expand-icon": {
    "format": "Ôāč",
    "tooltip": false
  },

  "custom/screenrecording-indicator": {
    "on-click": "omarchy-capture-screenrecording",
    "exec": "$OMARCHY_PATH/default/waybar/indicators/screen-recording.sh",
    "signal": 8,
    "return-type": "json"
  },

  "custom/voxtype": {
    "exec": "omarchy-voxtype-status",
    "return-type": "json",
    "format": "{icon}",
    "format-icons": {
      "idle": "",
      "recording": "ůįć¨",
      "transcribing": "ůįĒü"
    },
    "tooltip": true,
    "on-click-right": "omarchy-voxtype-config",
    "on-click": "omarchy-voxtype-model"
  },

  "hyprland/workspaces": {
    "on-click": "activate",
    "format": "{icon}",
    "format-icons": {
      "default": "ůįÉĘ",
      "1": "ůįĖü",
      "2": "ůį≠Ļ",
      "3": "ÔāĪ",
      "4": "ÔÉÄ",
      "5": "Ó∂Ą",
      "6": "ÔąÄ",
      "7": "ÓĶļ",
      "8": "8",
      "9": "Óė™"
    },
    
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": []
    }
  },

  "hyprland/window": {
    "format": "{title} - {class}",
    "max-length": 50,
    "rewrite": {
      "^ - $": "ůįüí  Desktop",
      "^(.*?)( - Chromium| ‚ÄĒ Chromium)? - chrome.*$": "ÔČ® $1",
      "(.*) - Obsidian - .* - obsidian": "ÔČä $1",
      "(.*nvim)...(.*)": "Óöģ $2",
      "(.*code) - (.*)": "ůį®ě $1",
      "^.*btop( .*|$)": "ůįß® BTOP$1",
      "^.*unimatrix( .*|$)": "ůįė® MATRIX$1",
      "(.*) - Spotify": "ÔÜľ $1",
      "(.*) - com.mitchellh.ghostty": "ůįä† $1",
      "(.*) - Alacritty": "ÔíČ  $1",
      "(.*) - kitty": "ÔíČ $1",
      "(.*) - BeeperTexts": " ůįĽě $1",
      "(.*Discord)...(.*).. (.*)": "ÔáŅ $2",
      "(.*) - org.gnome.Nautilus": "ůįČď $1",
      "(.*) - fish": "ÔíČ  [$1]",
      "(.*Steam)...(.*)": "ÔÜ∂ $1",
      "(.*imv)...(.*).. (.*)": "Ôď• $2",
      "(.*) - com.obsproject.Studio": "ÔĎá $1",
      "^(.*?)( ‚ÄĒ Zen Browser)? - zen$": "ÓĮł $1",
      "^(.*?)( - Sublime Text.*)? - sublime_text$": "ůįąô $1",
      "^(.*) - Outlook - outlook-for-linux$": "ůįīĘ $1",
      "^(.*) \\| (Microsoft )?Teams - teams-for-linux$": "ůįäĽ $1",
      "^(.*?)( - G4Music)? - com\\.github\\.fivves\\.gapless$": "ÔÄĀ $1",
      "^(.*) - com\\.jeffser\\.Nocturne$": "ÔÄĀ $1",
      "^(.*) - WhatsApp Desktop$": "Ôą≤ $1"
    }
  },

  "mpris": {
    "format": "{player_icon}  {artist} - {title}",
    "max-length": 50,
    "format-paused": "‚Źł {artist} - {title}",
    "format-stopped": "",
    "player": "comjeffserNocturne",
    "player-icons": {
      "default": "ÔÄĀ",
      "firefox": "Óėł",
      "Firefox": "ÓĮł",
      "Lollypop": "ůįĚö",
      "mpv": "ůįćļ",
      "vlc": "ůįēľ",
      "VLC": "ůįēľ",
      "Spotify": "ÔÜľ",
      "spotify": "ÔÜľ"
    },
    "escape": false,
    "truncate": "end",
    "interval": 1,
    "on-click": "playerctl --player comjeffserNocturne play-pause",
    "on-click-right": "playerctl --player comjeffserNocturne stop",
    "on-scroll-up": "playerctl --player comjeffserNocturne previous",
    "on-scroll-down": "playerctl --player comjeffserNocturne next"
  },

  "clock": {
    "format": "ůįÉį {:%a %b %d %I:%M %p}",
    "tooltip": false,
    "on-click": "omarchy-launch-or-focus-webapp Calendar 'https://calendar.notion.so/'",
    "on-click-right": "omarchy-cmd-tzupdate"
  },

  "network": {
    "format-icons": ["ůį§Į", "ůį§ü", "ůį§Ę", "ůį§•", "ůį§®"],
    "format": "{icon}",
    "format-wifi": "{icon}",
    "format-ethernet": "ůįÄā",
    "format-disconnected": "ůį§ģ",
    "tooltip-format-wifi": "{essid} ({frequency} GHz)\n‚á£{bandwidthDownBytes}  ‚á°{bandwidthUpBytes}",
    "tooltip-format-ethernet": "‚á£{bandwidthDownBytes}  ‚á°{bandwidthUpBytes}",
    "tooltip-format-disconnected": "Disconnected",
    "interval": 3,
    "spacing": 1,
    "on-click": "omarchy-launch-wifi"
  },

  "battery": {
    "format": "{capacity}% {icon}",
    "format-discharging": "{capacity}% {icon}",
    "format-charging": "{capacity}% {icon}",
    "format-plugged": "Ôá¶ {capacity}%",
    "format-full": "ůįāÖ",
    "format-icons": {
      "charging": ["ůįĘú", "ůįāÜ", "ůįāá", "ůįāą", "ůįĘĚ", "ůįāČ", "ůįĘě", "ůįāä", "ůįāč", "ůįāÖ"],
      "default": ["ůįĀļ", "ůįĀĽ", "ůįĀľ", "ůįĀĹ", "ůįĀĺ", "ůįĀŅ", "ůįāÄ", "ůįāĀ", "ůįāā", "ůįĀĻ"]
    },
    "tooltip-format-discharging": "{power:>1.0f}W‚Üď {capacity}%",
    "tooltip-format-charging": "{power:>1.0f}W‚ÜĎ {capacity}%",
    "interval": 5,
    "on-click": "omarchy-menu power",
    "on-click-right": "notify-send -u low \"$(omarchy-battery-status)\"",
    "states": {
      "warning": 20,
      "critical": 10
    }
  },

  "bluetooth": {
    "format": "ÔäĒ",
    "format-disabled": "ůįā≤",
    "format-off": "ůįā≤",
    "format-connected": "ůįāĪ",
    "format-no-controller": "",
    "tooltip-format": "Devices connected: {num_connections}",
    "on-click": "omarchy-launch-bluetooth"
  },

  "pulseaudio": {
    "format": "{icon}",
    "on-click": "$TERMINAL --class=Wiremix -e wiremix",
    "on-click-right": "pamixer -t",
    "tooltip-format": "Playing at {volume}%",
    "scroll-step": 5,
    "format-muted": "ÓĽ®",
    "format-icons": {
      "headphone": "ÔÄ•",
      "headset": "ÔÄ•",
      "default": ["ÔÄ¶", "ÔÄß", "ÔÄ®"]
    }
  },

  "cpu": {
    "interval": 5,
    "format": "ůįćõ",
    "on-click": "$TERMINAL -e btop"
  },

  "tray": {
    "icon-size": 12,
    "spacing": 12
  }
}
