{
  "reload_style_on_change": true,
  "output": "eDP-1",
  "layer": "top",
  "position": "top",
  "margin-top": 2,
  "margin-bottom": -8,

  "modules-left": [
    "group/left-main",
    "custom/codexbar",
    "mpris"
  ],
  "modules-center": ["hyprland/window"],
  "modules-right": [
    "custom/weather",
    "group/right-icons",
    "clock"
  ],

  "group/left-main": {
    "orientation": "inherit",
    "modules": ["custom/omarchy", "hyprland/workspaces"]
  },

  "group/right-icons": {
    "orientation": "inherit",
    "modules": [
      "custom/screenrecording-indicator",
      "group/tray-expander",
      "custom/wordle",
      "bluetooth",
      "network",
      "battery",
      "pulseaudio",
      "custom/idle-indicator",
      "custom/notification-silencing-indicator",
      "custom/update"
    ]
  },

  "group/tray-expander": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
      "children-class": "tray-group-item"
    },
    "modules": ["custom/expand-icon", "tray"]
  },

  "custom/omarchy": {
    "format": "<span font='JetBrainsMono Nerd Font 18'>σΑΘ΅</span>",
    "on-click": "omarchy-menu",
    "on-click-right": "omarchy-launch-terminal",
    "tooltip-format": "Omarchy Menu\n\nSuper + Alt + Space"
  },

  "custom/codexbar": {
    "exec": "codexbar",
    "format": "σΑö©  {}",
    "return-type": "json",
    "interval": 300,
    "signal": 12,
    "tooltip": true,
    "on-click": "xdg-open https://chatgpt.com/codex/settings/usage"
  },

  "custom/weather": {
    "exec": "waybar-weather",
    "restart-interval": 60,
    "return-type": "json",
    "hide-empty-text": true
  },

  "custom/wordle": {
    "exec": "python3 ~/.config/waybar/scripts/wordle.py",
    "return-type": "json",
    "interval": 3600,
    "signal": 8,
    "exec-on-event": false,
    "on-click": "bash ~/.config/waybar/scripts/wordle-guess.sh",
    "format": "{}",
    "tooltip": true,
    "escape": false
  },

  "custom/update": {
    "format": "οÄΓ",
    "exec": "omarchy-update-available",
    "on-click": "omarchy-launch-floating-terminal-with-presentation omarchy-update",
    "tooltip-format": "Omarchy update available",
    "signal": 7,
    "interval": 3600
  },

  "custom/idle-indicator": {
    "on-click": "omarchy-toggle-idle",
    "exec": "$OMARCHY_PATH/default/waybar/indicators/idle.sh",
    "signal": 9,
    "return-type": "json"
  },

  "custom/notification-silencing-indicator": {
    "on-click": "omarchy-toggle-notification-silencing",
    "exec": "$OMARCHY_PATH/default/waybar/indicators/notification-silencing.sh",
    "signal": 10,
    "return-type": "json"
  },

  "custom/expand-icon": {
    "format": "ο²΄ ",
    "tooltip": false
  },

  "custom/screenrecording-indicator": {
    "on-click": "omarchy-capture-screenrecording",
    "exec": "$OMARCHY_PATH/default/waybar/indicators/screen-recording.sh",
    "signal": 8,
    "return-type": "json"
  },

  "custom/voxtype": {
    "exec": "omarchy-voxtype-status",
    "return-type": "json",
    "format": "{icon}",
    "format-icons": {
      "idle": "",
      "recording": "σΑç§",
      "transcribing": "σΑîü"
    },
    "tooltip": true,
    "on-click-right": "omarchy-voxtype-config",
    "on-click": "omarchy-voxtype-model"
  },

  "hyprland/workspaces": {
    "on-click": "activate",
    "format": "{icon}",
    "format-icons": {
      "default": "σΑÉΔ",
      "1": "σΑ•ü",
      "2": "ο΅Ω",
      "3": "ο²±",
      "4": "οÉÄ",
      "5": "νΕ³",
      "6": "οàÄ",
      "7": "νΒΚ",
      "8": "8",
      "9": "ν‰Σ"
    },
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": []
    }
  },

  "hyprland/window": {
    "format": "{title} - {class}",
    "max-length": 50,
    "rewrite": {
      "^ - $": "σΑü£  Desktop",
      "^(.*?)( - Chromium| βÄî Chromium)? - chrome.*$": "οâ®  $1",
      "(.*) - Obsidian - .* - obsidian": "οâä  $1",
      "(.*nvim)...(.*)": "νö°  $2",
      "(.*code) - (.*)": "σΑ®û  $1",
      "^.*btop( .*|$)": "σΑß® BTOP $1",
      "^.*unimatrix( .*|$)": "σΑ‰® MATRIX $1",
      "(.*) - Spotify": "οÜΦ $1",
      "(.*) - com.mitchellh.ghostty": "σΑä† $1",
      "(.*) - Alacritty": "ο£â  $1",
      "(.*) - kitty": "ο£â  $1",
      "(.*) - BeeperTexts": " σΑΜû  $1",
      "(.*Discord)...(.*).. (.*)": "ο΅Ω  $2",
      "(.*) - org.gnome.Nautilus": "σΑâ™  $1",
      "(.*) - fish": "ο£â  [$1]",
      "(.*Steam)...(.*)": "οÜΕ  $1",
      "(.*imv)...(.*).. (.*)": "ο™Ξ  $2",
      "(.*) - com.obsproject.Studio": "οë΅ $1",
      "^(.*?)( βÄî Zen Browser)? - zen$": "ν·Η  $1",
      "^(.*?)( - Sublime Text.*)? - sublime_text$": "σΑàô  $1",
      "^(.*) - Outlook - outlook-for-linux$": "σΑ¥Δ  $1",
      "^(.*) \\| (Microsoft )?Teams - teams-for-linux$": "σΑäΜ  $1",
      "^(.*?)( - G4Music)? - com\\.github\\.fivves\\.gapless$": "οÄ¹  $1",
      "^(.*) - com\\.jeffser\\.Nocturne$": "οÄ¹  $1",
      "^(.*) - WhatsApp Desktop$": "οà≤  $1"
    }
  },

  "mpris": {
    "format": "{player_icon}  {artist} - {title}",
    "max-length": 50,
    "format-paused": "βèΗ {artist} - {title}",
    "format-stopped": "",
    "player": "comjeffserNocturne",
    "player-icons": {
      "default": "οÄ¹",
      "firefox": "ν‰Η",
      "Firefox": "ν·Η",
      "Lollypop": "σΑùö",
      "mpv": "σΑçΚ",
      "vlc": "σΑïΦ",
      "VLC": "σΑïΦ",
      "Spotify": "οÜΦ",
      "spotify": "οÜΦ"
    },
    "escape": false,
    "truncate": "end",
    "interval": 1,
    "on-click": "playerctl --player comjeffserNocturne play-pause",
    "on-click-right": "playerctl --player comjeffserNocturne stop",
    "on-scroll-up": "playerctl --player comjeffserNocturne previous",
    "on-scroll-down": "playerctl --player comjeffserNocturne next"
  },

  "clock": {
    "format": "σΑÉΑ  {:%a %b %d %I:%M %p}",
    "tooltip": false,
    "on-click": "omarchy-launch-or-focus-webapp Calendar 'https://calendar.notion.so/'",
    "on-click-right": "omarchy-cmd-tzupdate"
  },

  "network": {
    "format-icons": ["σΑΛ·", "σΑΛü", "σΑΛΔ", "σΑΛΞ", "σΑΛ®"],
    "format": "{icon}",
    "format-wifi": "{icon}",
    "format-ethernet": "σΑÄ²",
    "format-disconnected": "σΑΛ°",
    "tooltip-format-wifi": "{essid} ({frequency} GHz)\nβ΅Θ{bandwidthDownBytes}  β΅Γ{bandwidthUpBytes}",
    "tooltip-format-ethernet": "β΅Θ{bandwidthDownBytes}  β΅Γ{bandwidthUpBytes}",
    "tooltip-format-disconnected": "Disconnected",
    "interval": 3,
    "spacing": 1,
    "on-click": "omarchy-launch-wifi"
  },

  "battery": {
    "format": "{capacity}% {icon}",
    "format-discharging": "{capacity}% {icon}",
    "format-charging": "{capacity}% {icon}",
    "format-plugged": "ο΅Π {capacity}%",
    "format-full": "σΑ²Ö",
    "format-icons": {
      "charging": ["σΑΔ€", "σΑ²Ü", "σΑ²΅", "σΑ²à", "σΑΔù", "σΑ²â", "σΑΔû", "σΑ²ä", "σΑ²΄", "σΑ²Ö"],
      "default": ["σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"]
    },
    "tooltip-format-discharging": "{power:>1.0f}WβÜ™ {capacity}%",
    "tooltip-format-charging": "{power:>1.0f}WβÜë {capacity}%",
    "interval": 5,
    "on-click": "omarchy-menu power",
    "on-click-right": "notify-send -u low \"$(omarchy-battery-status)\"",
    "states": {
      "warning": 20,
      "critical": 10
    }
  },

  "bluetooth": {
    "format": "οäî",
    "format-disabled": "σΑ²≤",
    "format-off": "σΑ²≤",
    "format-connected": "σΑ²±",
    "format-no-controller": "",
    "tooltip-format": "Devices connected: {num_connections}",
    "on-click": "omarchy-launch-bluetooth"
  },

  "pulseaudio": {
    "format": "{icon}",
    "on-click": "$TERMINAL --class=Wiremix -e wiremix",
    "on-click-right": "pamixer -t",
    "tooltip-format": "Playing at {volume}%",
    "scroll-step": 5,
    "format-muted": "νΜ®",
    "format-icons": {
      "headphone": "οÄΞ",
      "headset": "οÄΞ",
      "default": ["οÄΠ", "οÄß", "οÄ®"]
    }
  },

  "cpu": {
    "interval": 5,
    "format": "σΑç¦",
    "on-click": "$TERMINAL -e btop"
  },

  "tray": {
    "icon-size": 12,
    "spacing": 12
  }
}
