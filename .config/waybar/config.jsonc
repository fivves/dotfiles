{
  "reload_style_on_change": true,
  "output": "DP-1",
  "layer": "top",
  "position": "top",
  "spacing": 0,

  "modules-left": [
    "custom/omarchy",
    "group/left-main",
    "custom/cava",
    "mpris"
  ],

  "modules-center": ["hyprland/window"],
  
  "modules-right": [
    "custom/codexbar",
    "custom/wordle",
    "custom/twitch",
    "custom/weather",
    "group/right-icons",
    "clock"
  ],

  "group/left-main": {
    "orientation": "inherit",
    "modules": ["hyprland/workspaces"]
  },

  "group/right-icons": {
    "orientation": "inherit",
    "modules": [
      "custom/screenrecording-indicator",
      "group/tray-expander",
      "bluetooth",
      "network",
      "battery",
      "pulseaudio",
      "custom/idle-indicator",
      "custom/notification-silencing-indicator",
      "custom/update"
    ]
  },

  "group/tray-expander": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
      "children-class": "tray-group-item"
    },
    "modules": ["custom/expand-icon", "tray"]
  },

  "custom/omarchy": {
    "format": "<span font='Flighter PERSONAL USE ONLY'> lucitt </span>",
    "on-click": "omarchy-menu",
    "on-click-right": "omarchy-launch-terminal",
    "tooltip-format": "Omarchy Menu\n\nSuper + Alt + Space"
  },

  "custom/codexbar": {
    "exec": "codexbar",
    "format": "¾░Ü® {}",
    "return-type": "json",
    "interval": 300,
    "signal": 12,
    "tooltip": true,
    "on-click": "xdg-open https://chatgpt.com/codex/settings/usage"
  },

"custom/weather": {
    "format": "{}¯ıü",
    "tooltip": true,
    "interval": 3600,
    "exec": "wttrbar --fahrenheit --nerd",
    "return-type": "json"
},

  "custom/wordle": {
    "exec": "python3 ~/.config/waybar/scripts/wordle.py",
    "return-type": "json",
    "interval": 3600,
    "signal": 8,
    "exec-on-event": false,
    "on-click": "bash ~/.config/waybar/scripts/wordle-guess.sh",
    "format": "{}",
    "tooltip": true,
    "escape": false
  },

  "custom/twitch": {
    "exec": "python3 ~/.config/waybar/scripts/twitch.py",
    "return-type": "json",
    "interval": 300,
    "format": "{}",
    "tooltip": true,
    "escape": true,
    "on-click": "bash ~/.config/waybar/scripts/twitch-menu.sh"
  },

  "custom/cava": {
    "exec": "bash ~/.config/waybar/scripts/cava.sh",
    "return-type": "json",
    "format": "{}",
    "exec-on-event": false,
    "tooltip": false
  },

  "custom/update": {
    "format": "´Çí",
    "exec": "omarchy-update-available",
    "on-click": "omarchy-launch-floating-terminal-with-presentation omarchy-update",
    "tooltip-format": "Omarchy update available",
    "signal": 7,
    "interval": 3600
  },

  "custom/idle-indicator": {
    "on-click": "omarchy-toggle-idle",
    "exec": "$OMARCHY_PATH/default/waybar/indicators/idle.sh",
    "signal": 9,
    "return-type": "json"
  },

  "custom/notification-silencing-indicator": {
    "on-click": "omarchy-toggle-notification-silencing",
    "exec": "$OMARCHY_PATH/default/waybar/indicators/notification-silencing.sh",
    "signal": 10,
    "return-type": "json"
  },

  "custom/expand-icon": {
    "format": "´éï",
    "tooltip": false
  },

  "custom/screenrecording-indicator": {
    "on-click": "omarchy-capture-screenrecording",
    "exec": "$OMARCHY_PATH/default/waybar/indicators/screen-recording.sh",
    "signal": 8,
    "return-type": "json"
  },

  "custom/voxtype": {
    "exec": "omarchy-voxtype-status",
    "return-type": "json",
    "format": "{icon}",
    "format-icons": {
      "idle": "",
      "recording": "¾░ı¼",
      "transcribing": "¾░öş"
    },
    "tooltip": true,
    "on-click-right": "omarchy-voxtype-config",
    "on-click": "omarchy-voxtype-model"
  },

  "hyprland/workspaces": {
    "on-click": "activate",
    "format": "{icon}",
    "format-icons": {
      "default": "¾░âó",
      "1": "¾░ûş",
      "2": "´åÂ",
      "3": "¾░ÄŞ",
      "4": "¾░åş",
      "5": "´üğ",
      "6": "6",
      "7": "7",
      "8": "8",
      "9": "¯İ¬"
    },
    
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": []
    }
  },

  "hyprland/window": {
    "format": "{title} - {class}",
    "max-length": 50,
    "rewrite": {
      "^ - $": "¾░şÆ  Desktop",
      "^(.*?)( - Chromium| ÔÇö Chromium)? - chrome.*$": "´ë¿ $1",
      "(.*) - Obsidian - .* - obsidian": "´ëè $1",
      "(.*nvim)...(.*)": "¯Ü« $2",
      "(.*code) - (.*)": "¾░¿Ş $1",
      "^.*btop( .*|$)": "¾░ğ¿ BTOP$1",
      "^.*unimatrix( .*|$)": "¾░İ¿ MATRIX$1",
      "(.*) - Spotify": "´å╝ $1",
      "(.*) - com.mitchellh.ghostty": "¾░èá $1",
      "(.*) - Alacritty": "´Æë  $1",
      "(.*) - kitty": "´Æë $1",
      "(.*) - BeeperTexts": " ¾░╗Ş $1",
      "(.*Discord)...(.*).. (.*)": "´ç┐ $2",
      "(.*) - org.gnome.Nautilus": "¾░ëô $1",
      "(.*) - fish": "´Æë  [$1]",
      "(.*Steam)...(.*)": "´åÂ $1",
      "(.*imv)...(.*).. (.*)": "´ôÑ $2",
      "(.*) - com.obsproject.Studio": "´æç $1",
      "^(.*?)( ÔÇö Zen Browser)? - zen$": "¯»© $1",
      "^(.*?)( - Sublime Text.*)? - sublime_text$": "¾░êÖ $1",
      "^(.*) - Outlook - outlook-for-linux$": "¾░┤ó $1",
      "^(.*) \\| (Microsoft )?Teams - teams-for-linux$": "¾░è╗ $1",
      "^(.*?)( - G4Music)? - com\\.github\\.fivves\\.gapless$": "´Çü $1",
      "^(.*) - io\\.m51\\.Gelly$": "´Çü $1",
      "^(.*) - WhatsApp Desktop$": "´ê▓ $1"
    }
  },

  "mpris": {
    "format": "{player_icon} {artist} - {title}",
    "max-length": 50,
    "format-paused": "ÔÅ© {artist} - {title}",
    "format-stopped": "",
    "player": "io",
    "player-icons": {
      "default": "´Çü",
      "firefox": "¯İ©",
      "Firefox": "¯»©",
      "Lollypop": "¾░ØÜ",
      "mpv": "¾░ı║",
      "vlc": "¾░ò╝",
      "VLC": "¾░ò╝",
      "Spotify": "´å╝",
      "spotify": "´å╝",
      "io": "´Çü"
    },
    "escape": false,
    "truncate": "end",
    "interval": 1,
    "on-click": "playerctl --player io.m51.Gelly play-pause",
    "on-click-right": "playerctl --player io.m51.Gelly stop",
    "on-scroll-up": "playerctl --player io.m51.Gelly previous",
    "on-scroll-down": "playerctl --player io.m51.Gelly next"
  },

  "clock": {
    "format": "¾░â░ {:%a %b %d %I:%M %p}",
    "tooltip": false,
    "on-click": "omarchy-launch-or-focus-webapp Calendar 'https://calendar.notion.so/'",
    "on-click-right": "omarchy-cmd-tzupdate"
  },

  "network": {
    "format-icons": ["¾░ñ»", "¾░ñş", "¾░ñó", "¾░ñÑ", "¾░ñ¿"],
    "format": "{icon}",
    "format-wifi": "{icon}",
    "format-ethernet": "¾░Çé",
    "format-disconnected": "¾░ñ«",
    "tooltip-format-wifi": "{essid} ({frequency} GHz)\nÔçú{bandwidthDownBytes}  Ôçí{bandwidthUpBytes}",
    "tooltip-format-ethernet": "Ôçú{bandwidthDownBytes}  Ôçí{bandwidthUpBytes}",
    "tooltip-format-disconnected": "Disconnected",
    "interval": 3,
    "spacing": 1,
    "on-click": "omarchy-launch-wifi"
  },

  "battery": {
    "format": "{capacity}% {icon}",
    "format-discharging": "{capacity}% {icon}",
    "format-charging": "{capacity}% {icon}",
    "format-plugged": "´çĞ {capacity}%",
    "format-full": "¾░éà",
    "format-icons": {
      "charging": ["¾░ó£", "¾░éå", "¾░éç", "¾░éê", "¾░óØ", "¾░éë", "¾░óŞ", "¾░éè", "¾░éï", "¾░éà"],
      "default": ["¾░ü║", "¾░ü╗", "¾░ü╝", "¾░ü¢", "¾░ü¥", "¾░ü┐", "¾░éÇ", "¾░éü", "¾░éé", "¾░ü╣"]
    },
    "tooltip-format-discharging": "{power:>1.0f}WÔåô {capacity}%",
    "tooltip-format-charging": "{power:>1.0f}WÔåæ {capacity}%",
    "interval": 5,
    "on-click": "omarchy-menu power",
    "on-click-right": "notify-send -u low \"$(omarchy-battery-status)\"",
    "states": {
      "warning": 20,
      "critical": 10
    }
  },

  "bluetooth": {
    "format": "´èö",
    "format-disabled": "¾░é▓",
    "format-off": "¾░é▓",
    "format-connected": "¾░é▒",
    "format-no-controller": "",
    "tooltip-format": "Devices connected: {num_connections}",
    "on-click": "omarchy-launch-bluetooth"
  },

  "pulseaudio": {
    "format": "{icon}",
    "on-click": "$TERMINAL --class=Wiremix -e wiremix",
    "on-click-right": "pamixer -t",
    "tooltip-format": "Playing at {volume}%",
    "scroll-step": 5,
    "format-muted": "¯╗¿",
    "format-icons": {
      "headphone": "´ÇÑ",
      "headset": "´ÇÑ",
      "default": ["´ÇĞ", "´Çğ", "´Ç¿"]
    }
  },

  "cpu": {
    "interval": 5,
    "format": "¾░ıø",
    "on-click": "$TERMINAL -e btop"
  },

  "tray": {
    "icon-size": 12,
    "spacing": 12
  }
}
