  textarea,
  select,
  search-textbox,
  .search-wrapper input,
  .fake-textbox,
  .tile,
  .top-site-outer .tile,
  .card,
  .ds-card,
  .personalize-button,
  button {
    background-color: color-mix(in srgb, $background 86%, $foreground 14%) !important;
    color: $foreground !important;
    border-color: $border !important;
  }

  a,
  button,
  .icon,
  .context-menu-button,
  .top-site-icon {
    color: $accent !important;
    fill: $accent !important;
  }
