#!/usr/bin/env bash
set -uo pipefail

INSTALLER_PATH="$HOME/.local/bin/install-omarchy-zen-theme-sync"
HOOK_DIR="$HOME/.config/omarchy/hooks/theme-set.d"
HOOK_PATH="$HOOK_DIR/sync-zen-browser"
THEME_DIR="$HOME/.config/omarchy/current/theme"
COLORS_FILE="$THEME_DIR/colors.toml"

log() {
  printf 'omarchy-zen-theme-sync: %s\n' "$*" >&2
}

usage() {
  cat <<'USAGE'
Usage:
  install-omarchy-zen-theme-sync          Install the Omarchy hook and sync Zen now
  install-omarchy-zen-theme-sync --sync   Sync existing Zen profiles now

The hook runs after `omarchy theme set ...` and writes generated
chrome/omarchy-theme.css and chrome/omarchy-content.css files into each Zen
profile.
USAGE
}

toml_color() {
  local key="$1"
  local fallback="$2"
  local value=""

  if [[ -f "$COLORS_FILE" ]]; then
    value=$(
      awk -F= -v key="$key" '
        function trim(s) {
          gsub(/^[[:space:]]+|[[:space:]]+$/, "", s)
          return s
        }
        {
          lhs = trim($1)
          if (lhs == key) {
            rhs = $0
            sub(/^[^=]*=/, "", rhs)
            rhs = trim(rhs)
            gsub(/"/, "", rhs)
            gsub(/\047/, "", rhs)
            print rhs
            exit
          }
        }
      ' "$COLORS_FILE"
    )
  fi

  if [[ "$value" =~ ^#[0-9A-Fa-f]{6}$ ]]; then
    printf '%s' "$value"
  else
    printf '%s' "$fallback"
  fi
}

hex_to_rgb() {
  local hex="${1#\#}"
  printf '%d %d %d' "0x${hex:0:2}" "0x${hex:2:2}" "0x${hex:4:2}"
}

css_scheme() {
  if [[ -f "$THEME_DIR/light.mode" ]]; then
    printf 'light'
  else
    printf 'dark'
  fi
}

theme_name() {
  if [[ -f "$HOME/.config/omarchy/current/theme.name" ]]; then
    tr -d '\r\n' <"$HOME/.config/omarchy/current/theme.name"
  else
    printf 'unknown'
  fi
}

write_zen_css() {
  local css_path="$1"
  local color4 background foreground accent cursor selection_background selection_foreground border secondary scheme name
  local bg_r bg_g bg_b accent_r accent_g accent_b sel_r sel_g sel_b

  color4=$(toml_color color4 "#3b82f6")
  background=$(toml_color background "#1b1b1b")
  foreground=$(toml_color foreground "#ebebeb")
  accent=$(toml_color accent "$color4")
  cursor=$(toml_color cursor "$accent")
  selection_background=$(toml_color selection_background "$accent")
  selection_foreground=$(toml_color selection_foreground "$background")
  border=$(toml_color color8 "$accent")
  secondary=$(toml_color color5 "$accent")
  scheme=$(css_scheme)
  name=$(theme_name)

  read -r bg_r bg_g bg_b <<<"$(hex_to_rgb "$background")"
  read -r accent_r accent_g accent_b <<<"$(hex_to_rgb "$accent")"
  read -r sel_r sel_g sel_b <<<"$(hex_to_rgb "$selection_background")"

  cat >"$css_path" <<CSS
/* Generated by install-omarchy-zen-theme-sync from Omarchy theme: $name */
:root {
  --omarchy-zen-background: $background;
  --omarchy-zen-foreground: $foreground;
  --omarchy-zen-accent: $accent;
  --omarchy-zen-cursor: $cursor;
  --omarchy-zen-selection-background: $selection_background;
  --omarchy-zen-selection-foreground: $selection_foreground;
  --omarchy-zen-border: $border;
  --omarchy-zen-secondary: $secondary;

  color-scheme: $scheme !important;
  accent-color: var(--omarchy-zen-accent) !important;

  --zen-primary-color: var(--omarchy-zen-accent) !important;
  --zen-branding-bg: var(--omarchy-zen-background) !important;
  --zen-branding-bg-reverse: var(--omarchy-zen-foreground) !important;
  --zen-main-browser-background: var(--omarchy-zen-background) !important;
  --zen-main-browser-background-toolbar: color-mix(in srgb, var(--omarchy-zen-background) 88%, var(--omarchy-zen-accent) 12%) !important;
  --zen-themed-toolbar-bg-transparent: rgba($bg_r, $bg_g, $bg_b, 0.78) !important;

  --zen-colors-primary: color-mix(in srgb, var(--omarchy-zen-accent) 32%, var(--omarchy-zen-background) 68%) !important;
  --zen-colors-secondary: color-mix(in srgb, var(--omarchy-zen-accent) 18%, var(--omarchy-zen-background) 82%) !important;
  --zen-colors-tertiary: color-mix(in srgb, var(--omarchy-zen-accent) 7%, var(--omarchy-zen-background) 93%) !important;
  --zen-colors-border: color-mix(in srgb, var(--omarchy-zen-foreground) 18%, transparent) !important;
  --zen-colors-border-contrast: color-mix(in srgb, var(--omarchy-zen-accent) 24%, transparent) !important;
  --zen-colors-input-bg: color-mix(in srgb, var(--omarchy-zen-background) 88%, var(--omarchy-zen-foreground) 12%) !important;
  --zen-urlbar-background: color-mix(in srgb, var(--omarchy-zen-background) 86%, var(--omarchy-zen-accent) 14%) !important;
  --zen-dialog-background: color-mix(in srgb, var(--omarchy-zen-background) 94%, var(--omarchy-zen-foreground) 6%) !important;
  --zen-in-content-dialog-background: var(--zen-dialog-background) !important;

  --toolbar-bgcolor: rgba($bg_r, $bg_g, $bg_b, 0.72) !important;
  --toolbox-textcolor: var(--omarchy-zen-foreground) !important;
  --toolbar-color: var(--omarchy-zen-foreground) !important;
  --toolbar-field-color: var(--omarchy-zen-foreground) !important;
  --toolbar-field-background-color: var(--zen-urlbar-background) !important;
  --toolbar-field-focus-background-color: color-mix(in srgb, var(--omarchy-zen-background) 72%, var(--omarchy-zen-accent) 28%) !important;
  --toolbarbutton-icon-fill: var(--omarchy-zen-foreground) !important;
  --toolbarbutton-icon-fill-attention: var(--omarchy-zen-accent) !important;
  --toolbarbutton-hover-background: rgba($accent_r, $accent_g, $accent_b, 0.18) !important;
  --toolbarbutton-active-background: rgba($accent_r, $accent_g, $accent_b, 0.28) !important;

  --tab-selected-bgcolor: rgba($accent_r, $accent_g, $accent_b, 0.22) !important;
  --tab-selected-textcolor: var(--omarchy-zen-foreground) !important;
  --tab-hover-background-color: rgba($accent_r, $accent_g, $accent_b, 0.14) !important;

  --lwt-accent-color: var(--omarchy-zen-background) !important;
  --lwt-text-color: var(--omarchy-zen-foreground) !important;
  --lwt-selected-tab-background-color: rgba($accent_r, $accent_g, $accent_b, 0.22) !important;

  --arrowpanel-background: color-mix(in srgb, var(--omarchy-zen-background) 92%, var(--omarchy-zen-foreground) 8%) !important;
  --arrowpanel-color: var(--omarchy-zen-foreground) !important;
  --panel-background: var(--arrowpanel-background) !important;
  --panel-color: var(--omarchy-zen-foreground) !important;
  --panel-border-color: var(--omarchy-zen-border) !important;

  --input-bgcolor: color-mix(in srgb, var(--omarchy-zen-background) 88%, var(--omarchy-zen-foreground) 12%) !important;
  --input-color: var(--omarchy-zen-foreground) !important;
  --focus-outline-color: var(--omarchy-zen-accent) !important;
  --in-content-accent-color: var(--omarchy-zen-accent) !important;
  --selection-bgcolor: rgba($sel_r, $sel_g, $sel_b, 0.75) !important;
  --selection-color: var(--omarchy-zen-selection-foreground) !important;
}

#navigator-toolbox,
#zen-main-app-wrapper,
#zen-sidebar-top-buttons,
#titlebar,
#nav-bar {
  color: var(--omarchy-zen-foreground) !important;
}

#urlbar-background,
#searchbar {
  background: var(--zen-urlbar-background) !important;
  border-color: var(--omarchy-zen-border) !important;
}

.tabbrowser-tab[selected] .tab-background {
  background: color-mix(in srgb, var(--omarchy-zen-accent) 24%, var(--omarchy-zen-background) 76%) !important;
}

#zen-workspaces-button,
#zen-current-workspace-indicator {
  color: var(--omarchy-zen-accent) !important;
}

#main-window,
#browser,
#tabbrowser-tabbox,
#tabbrowser-tabpanels,
#zen-main-app-wrapper,
#zen-appcontent-wrapper,
#zen-browser-background,
.zen-browser-generic-background,
.browserStack,
.browserContainer {
  background-color: var(--omarchy-zen-background) !important;
}

#zen-browser-background,
.zen-browser-generic-background::before,
.zen-browser-generic-background::after {
  background: var(--omarchy-zen-background) !important;
  opacity: 1 !important;
}
CSS
}

write_zen_content_css() {
  local css_path="$1"
  local color4 background foreground accent cursor selection_background selection_foreground border scheme name
  local bg_r bg_g bg_b accent_r accent_g accent_b sel_r sel_g sel_b

  color4=$(toml_color color4 "#3b82f6")
  background=$(toml_color background "#1b1b1b")
  foreground=$(toml_color foreground "#ebebeb")
  accent=$(toml_color accent "$color4")
  cursor=$(toml_color cursor "$accent")
  selection_background=$(toml_color selection_background "$accent")
  selection_foreground=$(toml_color selection_foreground "$background")
  border=$(toml_color color8 "$accent")
  scheme=$(css_scheme)
  name=$(theme_name)

  read -r bg_r bg_g bg_b <<<"$(hex_to_rgb "$background")"
  read -r accent_r accent_g accent_b <<<"$(hex_to_rgb "$accent")"
  read -r sel_r sel_g sel_b <<<"$(hex_to_rgb "$selection_background")"

  cat >"$css_path" <<CSS
/* Generated by install-omarchy-zen-theme-sync from Omarchy theme: $name */
@-moz-document url("about:home"),
  url("about:newtab"),
  url("about:blank"),
  url-prefix("about:preferences"),
  url-prefix("about:addons"),
  url-prefix("about:downloads"),
  url-prefix("about:config"),
  url-prefix("about:privatebrowsing") {
  :root,
  html,
  body,
  #root,
  main,
  .activity-stream,
  .outer-wrapper,
  .main-content,
  .non-collapsible-section,
  .body-wrapper,
  .discovery-stream.ds-layout {
    color-scheme: $scheme !important;
    background: $background !important;
    background-color: $background !important;
    color: $foreground !important;
    accent-color: $accent !important;
    caret-color: $cursor !important;
    --newtab-background-color: $background !important;
    --newtab-background-color-secondary: color-mix(in srgb, $background 88%, $foreground 12%) !important;
    --newtab-text-primary-color: $foreground !important;
    --newtab-text-secondary-color: color-mix(in srgb, $foreground 68%, $background 32%) !important;
    --newtab-primary-action-background: $accent !important;
    --newtab-primary-element-active-color: rgba($accent_r, $accent_g, $accent_b, 0.28) !important;
    --newtab-primary-element-hover-color: rgba($accent_r, $accent_g, $accent_b, 0.18) !important;
    --in-content-page-background: $background !important;
    --in-content-page-color: $foreground !important;
    --in-content-primary-button-background: $accent !important;
    --in-content-primary-button-text-color: $selection_foreground !important;
    --in-content-accent-color: $accent !important;
    --in-content-border-color: $border !important;
  }

  *::selection {
    background: rgba($sel_r, $sel_g, $sel_b, 0.75) !important;
    color: $selection_foreground !important;
  }

