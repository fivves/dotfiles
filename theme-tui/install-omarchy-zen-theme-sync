}

ensure_user_chrome_import() {
  local user_chrome="$1"
  local import_line='@import url("omarchy-theme.css");'
  local tmp

  if [[ ! -f "$user_chrome" ]]; then
    printf '%s\n' "$import_line" >"$user_chrome"
    return
  fi

  if grep -Fq 'omarchy-theme.css' "$user_chrome"; then
    return
  fi

  tmp=$(mktemp "${user_chrome}.tmp.XXXXXX")
  {
    printf '%s\n\n' "$import_line"
    cat "$user_chrome"
  } >"$tmp"
  mv "$tmp" "$user_chrome"
}

ensure_user_content_import() {
  local user_content="$1"
  local import_line='@import url("omarchy-content.css");'
  local tmp

  if [[ ! -f "$user_content" ]]; then
    printf '%s\n' "$import_line" >"$user_content"
    return
  fi

  if grep -Fq 'omarchy-content.css' "$user_content"; then
    return
  fi

  tmp=$(mktemp "${user_content}.tmp.XXXXXX")
  {
    printf '%s\n\n' "$import_line"
    cat "$user_content"
  } >"$tmp"
  mv "$tmp" "$user_content"
}

set_user_pref() {
  local pref_file="$1"
  local key="$2"
  local value="$3"
  local tmp

  touch "$pref_file"
  tmp=$(mktemp "${pref_file}.tmp.XXXXXX")
  awk -v key="$key" -v line="user_pref(\"$key\", $value);" '
    index($0, "user_pref(\"" key "\",") == 1 {
      if (!done) {
        print line
        done = 1
      }
      next
    }
    { print }
    END {
      if (!done) {
        print line
      }
    }
  ' "$pref_file" >"$tmp"
  mv "$tmp" "$pref_file"
}

add_profile() {
  local profile="$1"

  [[ -d "$profile" ]] || return
  [[ -n "${seen_profiles[$profile]+set}" ]] && return

  seen_profiles[$profile]=1
  profiles+=("$profile")
}

collect_profiles() {
  local root path profile
  profiles=()
  declare -gA seen_profiles=()

  for root in \
    "$HOME/.config/zen" \
    "$HOME/.zen" \
    "$HOME/.var/app/app.zen_browser.zen/.config/zen" \
    "$HOME/.var/app/app.zen_browser.zen/.zen"; do
    [[ -d "$root" ]] || continue

    if [[ -f "$root/profiles.ini" ]]; then
      while IFS= read -r path; do
        [[ -n "$path" ]] || continue
        if [[ "$path" == /* ]]; then
          add_profile "$path"
        else
          add_profile "$root/$path"
        fi
      done < <(awk -F= '$1 == "Path" { print substr($0, index($0, "=") + 1) }' "$root/profiles.ini")
    fi

    while IFS= read -r -d '' profile; do
      if [[ -f "$profile/prefs.js" || -f "$profile/compatibility.ini" || -f "$profile/chrome/zen-themes.css" ]]; then
        add_profile "$profile"
      fi
    done < <(find "$root" -mindepth 1 -maxdepth 1 -type d -print0)
  done
}

sync_profiles() {
  local profile chrome_dir css_path content_css_path updated=0

  if [[ ! -f "$COLORS_FILE" ]]; then
    log "No Omarchy colors found at $COLORS_FILE"
    return 0
  fi

  collect_profiles

  if (( ${#profiles[@]} == 0 )); then
    log "No Zen profiles found yet. Open Zen once, then run this script again."
    return 0
  fi

  for profile in "${profiles[@]}"; do
    chrome_dir="$profile/chrome"
    css_path="$chrome_dir/omarchy-theme.css"
    content_css_path="$chrome_dir/omarchy-content.css"

    mkdir -p "$chrome_dir"
    write_zen_css "$css_path"
    write_zen_content_css "$content_css_path"
    ensure_user_chrome_import "$chrome_dir/userChrome.css"
    ensure_user_content_import "$chrome_dir/userContent.css"
    set_user_pref "$profile/user.js" "toolkit.legacyUserProfileCustomizations.stylesheets" "true"
    updated=$((updated + 1))
  done

  log "Synced Omarchy colors into $updated Zen profile(s). Restart Zen to load first-time chrome/content CSS setup."
}

install_hook() {
  local source_path target_path

  mkdir -p "$HOME/.local/bin" "$HOOK_DIR"

  source_path=$(realpath -m "${BASH_SOURCE[0]}")
  target_path=$(realpath -m "$INSTALLER_PATH")
  if [[ "$source_path" != "$target_path" ]]; then
    cp "$source_path" "$INSTALLER_PATH"
  fi
  chmod +x "$INSTALLER_PATH"

  cat >"$HOOK_PATH" <<'HOOK'
#!/usr/bin/env bash
exec "$HOME/.local/bin/install-omarchy-zen-theme-sync" --sync "$@"
HOOK
  chmod +x "$HOOK_PATH"

  log "Installed hook at $HOOK_PATH"
  "$INSTALLER_PATH" --sync
}

case "${1:-}" in
  ""|--install)
    install_hook
    ;;
  --sync)
    shift
    sync_profiles "$@"
    ;;
  -h|--help)
    usage
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
